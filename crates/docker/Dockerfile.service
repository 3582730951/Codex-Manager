FROM rust:1-bookworm AS builder

WORKDIR /src

# 先拷贝 manifests，尽量利用 Docker layer cache
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates

RUN cargo build -p codexmanager-service --release

FROM debian:bookworm-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/codexmanager-service /usr/local/bin/codexmanager-service

ENV CODEXMANAGER_SERVICE_ADDR=0.0.0.0:48760
ENV CODEXMANAGER_DB_PATH=/data/codexmanager.db
ENV CODEXMANAGER_ACCOUNT_MAX_INFLIGHT=2
ENV CODEXMANAGER_ROUTE_LOAD_AWARE_ENABLED=1
ENV CODEXMANAGER_ROUTE_LOAD_ORDERED_WINDOW=3
ENV CODEXMANAGER_ROUTE_LOAD_BALANCED_WINDOW=2
ENV CODEXMANAGER_USAGE_REFRESH_WORKERS=2
ENV CODEXMANAGER_HTTP_WORKER_FACTOR=2
ENV CODEXMANAGER_HTTP_WORKER_MIN=4
ENV CODEXMANAGER_HTTP_STREAM_WORKER_FACTOR=1
ENV CODEXMANAGER_HTTP_STREAM_WORKER_MIN=2
ENV CODEXMANAGER_HTTP_QUEUE_FACTOR=2
ENV CODEXMANAGER_HTTP_QUEUE_MIN=16
ENV CODEXMANAGER_HTTP_STREAM_QUEUE_FACTOR=1
ENV CODEXMANAGER_HTTP_STREAM_QUEUE_MIN=8

VOLUME ["/data"]
EXPOSE 48760

CMD ["codexmanager-service"]
