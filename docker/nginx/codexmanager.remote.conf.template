server {
  listen 80;
  server_name __SERVER_NAME__;

  client_max_body_size 64m;

  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;

  location = /health {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-service:48760/health;
  }

  location = /metrics {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-service:48760/metrics;
  }

  location = /rpc {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-service:48760/rpc;
  }

  location /v1/ {
    proxy_http_version 1.1;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    add_header X-Accel-Buffering no;
    proxy_pass http://codexmanager-service:48760;
  }

  location /oauth/ {
    proxy_http_version 1.1;
    proxy_buffering off;
    proxy_request_buffering off;
    add_header X-Accel-Buffering no;
    proxy_pass http://codexmanager-service:48760;
  }

  location /auth/ {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-service:48760;
  }

  location /api/accounts/deviceauth/ {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-service:48760;
  }

  location /codex/device {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-service:48760;
  }

  location /api/runtime {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-web:48761;
  }

  location /api/rpc {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-web:48761;
  }

  location /__auth_status {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-web:48761;
  }

  location /__login {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-web:48761;
  }

  location /__logout {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-web:48761;
  }

  location / {
    proxy_http_version 1.1;
    proxy_pass http://codexmanager-web:48761;
  }
}
